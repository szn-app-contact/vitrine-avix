# Variables d'environnement AVIX
# Copiez ce fichier en .env.local et remplissez les valeurs
# NE JAMAIS commiter .env.local sur Git

# Resend — Service d'envoi d'email
# Créer un compte sur https://resend.com et générer une clé API
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Email de destination (où reçoit AVIX)
CONTACT_EMAIL=avix.digital.contact@gmail.com

# Adresse expéditrice (doit correspondre à un domaine vérifié sur Resend)
# Si le domaine avix-digital.com n'est pas encore vérifié → utiliser :
#   FROM_EMAIL=AVIX <onboarding@resend.dev>
# Une fois le domaine vérifié → remplacer par :
#   FROM_EMAIL=AVIX <contact@avix-digital.com>
FROM_EMAIL=AVIX <onboarding@resend.dev>
